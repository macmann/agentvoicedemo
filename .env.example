# Copy to .env.local for local development.
# OPENAI_API_KEY is optional; if omitted, the app runs in mock mode.
OPENAI_API_KEY=sk-your-openai-key

# Optional model overrides
OPENAI_UNDERSTANDING_MODEL=gpt-5-mini
OPENAI_RESPONSE_MODEL=gpt-5-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Optional OpenAI-compatible base URL
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional site URL used by some deployments
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional OSS Support Portal API (for real outage/status tool calls in API mode)
OSS_SUPPORT_PORTAL_BASE_URL=https://api.oss-support-portal.example.com
OSS_SUPPORT_PORTAL_API_KEY=your-support-portal-api-key

# OSS Support Portal API (live tool mode)
OSS_PORTAL_BASE_URL=https://status.oss-portal.example.com
OSS_PORTAL_API_KEY=your-oss-portal-api-key
